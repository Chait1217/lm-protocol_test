# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Base mainnet (chain id 8453) – native USDC, real funds
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_BASE_VAULT_ADDRESS=0x...
NEXT_PUBLIC_BASE_MARGIN_ENGINE_ADDRESS=0x...

# Polygon (chain id 137) – real Polymarket execution
NEXT_PUBLIC_POLYGON_CHAIN_ID=137
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_RPC_ALLOW_PUBLIC_FALLBACK=true
NEXT_PUBLIC_POLYMKT_USDCE_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEXT_PUBLIC_POLYMKT_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
NEXT_PUBLIC_POLYMKT_CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# Contracts used by trade-demo components
NEXT_PUBLIC_USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEXT_PUBLIC_VAULT_ADDRESS=0x...
NEXT_PUBLIC_MARGIN_ENGINE_ADDRESS=0x...

# Oracle setup (oracle-driven settlement). Set POLYMARKET_FEED_PRIVATE_KEY to the updater key (must match feed.updater); use scripts/set-polymarket-feed-updater.js if needed.
NEXT_PUBLIC_MARKET_SLUG=will-the-iranian-regime-fall-by-june-30
POLYMARKET_MARKET_SLUG=will-the-iranian-regime-fall-by-june-30
NEXT_PUBLIC_MARKET_ID=0x0f4f0800c154f98b8fdbd46c02f7f157293736f2d5e07c1306edbf46a64db22f
NEXT_PUBLIC_ORACLE_ROUTER_ADDRESS=0x...
POLYMARKET_FEED_PRIVATE_KEY=0x...
NEXT_PUBLIC_ORACLE_CHAINLINK_ADAPTER_ADDRESS=0x...
NEXT_PUBLIC_ORACLE_UMA_ADAPTER_ADDRESS=0x...

# Optional: Polymarket Builder credentials for proxy wallet (trades visible on polymarket.com)
# Get from https://polymarket.com/settings?tab=builder — then set the values in .env.local (do not commit .env.local).
NEXT_PUBLIC_POLYMARKET_BUILDER_API_KEY=your_builder_api_key
POLYMARKET_BUILDER_SECRET=your_builder_secret
POLYMARKET_BUILDER_PASSPHRASE=your_builder_passphrase

# Treasury address for fee collection (20% of all fees)
NEXT_PUBLIC_TREASURY_ADDRESS=0x...
